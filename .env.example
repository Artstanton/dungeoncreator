# Copy this to .env and fill in values. .env is gitignored.

# --- Grok (xAI) API ---
# xAI's API is OpenAI-compatible; we use the openai SDK pointed at this base URL.
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4

# --- Server ---
API_PORT=4000
WEB_PORT=5173
NODE_ENV=development

# --- Auth ---
# Used to sign session cookies. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Database ---
# SQLite file path. Created automatically on first run.
DATABASE_URL=file:./data/dev.db
