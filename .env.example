# Copy this to .env and fill in values. .env is gitignored.

# --- Grok (xAI) API ---
# xAI's API is OpenAI-compatible; we use the openai SDK pointed at this base URL.
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4-1-fast-reasoning

# --- Server ---
API_PORT=4000
WEB_PORT=5173
NODE_ENV=development

# --- Database ---
# SQLite file, relative to apps/api/prisma/ (where schema.prisma lives).
# ../../data/dev.db resolves to <repo-root>/data/dev.db — already gitignored.
DATABASE_URL=file:../../data/dev.db
